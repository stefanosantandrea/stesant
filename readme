graph TB
    %% DBA Layer
    subgraph "LAYER 1 - DBA / Client"
        DBA[DBA<br/>VS Code + Cline]
        CLIENT[Client MCP]
    end
    
    %% LLM Layer
    subgraph "LAYER 2 - AI Orchestration"
        LLM[LLM Provider<br/>Claude API / Azure OpenAI / Bedrock]
    end
    
    %% MCP Servers Layer
    subgraph "LAYER 3 - MCP Servers<br/>Data Access Layer"
        SQLCL[SQLcl MCP Server<br/>Oracle<br/>sql.exe -mcp -restrict 1]
        MSSQL[SQL Server MCP<br/>sqlcmd wrapper]
        PG[PostgreSQL MCP<br/>psql wrapper]
        MYSQL[MySQL MCP<br/>mysql wrapper]
    end
    
    %% Database Layer
    subgraph "LAYER 4 - Database"
        ORACLE[Oracle CDB/PDB<br/>Prod/Test/Dev]
        SQLSERV[SQL Server<br/>Prod/Test]
        POSTGRES[PostgreSQL<br/>Prod/Test]
        MYDB[MySQL<br/>Prod/Test]
    end
    
    %% Governance Layer
    subgraph "LAYER 5 - Governance"
        SIEM[SIEM / Audit<br/>Splunk/Elastic]
        SECRETS[Secret Manager<br/>Vault/AWS Secrets<br/>Oracle Wallet]
    end
    
    %% Flussi
    DBA --> CLIENT
    CLIENT --> LLM
    CLIENT -.->|Tool calls| SQLCL
    CLIENT -.->|Tool calls| MSSQL
    CLIENT -.->|Tool calls| PG
    CLIENT -.->|Tool calls| MYSQL
    
    SQLCL --> ORACLE
    MSSQL --> SQLSERV
    PG --> POSTGRES
    MYSQL --> MYDB
    
    SQLCL -.->|Secrets| SECRETS
    MSSQL -.->|Secrets| SECRETS
    PG -.->|Secrets| SECRETS
    
    SQLCL -.->|Audit| SIEM
    MSSQL -.->|Audit| SIEM
    PG -.->|Audit| SIEM
    
    classDef dbClient fill:#e1f5fe
    classDef dbServer fill:#f3e5f5
    classDef db fill:#e8f5e8
    classDef governance fill:#fff3e0
    
    class SQLCL,MSSQL,PG,MYSQL dbServer
    class ORACLE,SQLSERV,POSTGRES,MYDB db
    class SIEM,SECRETS governance
